APP_ENV=development
PORT=8000
API_VERSION=1.0.0
ALLOWED_ORIGINS=*

# Firebase (one of these)
FIREBASE_CREDENTIALS=path/to/service-account.json
FIREBASE_CREDENTIALS_JSON=

# Admin
ADMIN_SECRET=

# Quantum backends
PILOTOS_API_KEY=
PILOTOS_HOST=localhost
PILOTOS_PORT=7100
IBM_QUANTUM_TOKEN=

# Monitoring
SENTRY_DSN=

# Rate limits
DEMO_RATE_LIMIT=10
CIRCUIT_TIMEOUT=30
